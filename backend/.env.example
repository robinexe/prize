# Environment variables for Prize Clube Backend

# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prize_clube?schema=public"

# JWT
JWT_SECRET=prize-clube-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=prize-clube-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Google Gemini AI
GEMINI_API_KEY=AIzaSyDcxe6EglL_UjcI8o6m6q1Z275KOO8xSBw

# AWS S3 (for file uploads)
AWS_REGION=sa-east-1
AWS_BUCKET=prize-clube-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Firebase (push notifications)
FIREBASE_PROJECT_ID=prize-clube
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Frontend URLs (CORS)
ADMIN_URL=http://localhost:3001
MOBILE_URL=http://localhost:8081
